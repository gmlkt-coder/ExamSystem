@model ExamSystem.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Profile" class="btn btn-sm btn-outline-secondary me-3">
        <i class="fas fa-arrow-left me-1"></i>Quay lại
    </a>
    <h4 class="fw-bold mb-0"><i class="fas fa-key me-2 text-primary"></i>Đổi mật khẩu</h4>
</div>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body p-4">
                <div class="alert alert-light border small">
                    Sau khi đổi sang mật khẩu riêng của bạn, quản trị viên sẽ không thể biết mật khẩu hiện tại.
                </div>

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <div class="mb-3">
                        <label asp-for="OldPassword" class="form-label fw-semibold small"></label>
                        <input asp-for="OldPassword" class="form-control" type="password" placeholder="Nhập mật khẩu hiện tại" />
                        <span asp-validation-for="OldPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold small"></label>
                        <input asp-for="NewPassword" class="form-control" type="password" placeholder="Nhập mật khẩu mới" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold small"></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Nhập lại mật khẩu mới" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-save me-1"></i>Đổi mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

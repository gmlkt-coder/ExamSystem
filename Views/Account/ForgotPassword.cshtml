@model ExamSystem.ViewModels.ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Quên mật khẩu";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quên mật khẩu - ExamSystem</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 60%, #38bdf8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: "Segoe UI", sans-serif;
        }
        .request-card {
            width: 460px;
            border-radius: 18px;
            box-shadow: 0 22px 50px rgba(15, 23, 42, .25);
        }
    </style>
</head>
<body>
    <div class="card request-card border-0">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="mb-3 text-primary" style="font-size:2.2rem"><i class="fas fa-unlock-alt"></i></div>
                <h3 class="fw-bold mb-1">Quên mật khẩu</h3>
                <p class="text-muted mb-0">Gửi yêu cầu để quản trị viên cấp mật khẩu tạm</p>
            </div>

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-semibold"></label>
                    <input asp-for="Username" class="form-control" placeholder="Nhập mã sinh viên hoặc mã giáo viên" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" placeholder="Email đã đăng ký, nếu có" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Message" class="form-label fw-semibold"></label>
                    <textarea asp-for="Message" class="form-control" rows="3" placeholder="Ví dụ: Em quên mật khẩu, nhờ admin cấp lại."></textarea>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-paper-plane me-2"></i>Gửi yêu cầu
                </button>
            </form>

            <div class="text-center mt-4">
                <a asp-action="Login" class="text-decoration-none">Quay lại đăng nhập</a>
            </div>
        </div>
    </div>
</body>
</html>

@model ExamSystem.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="fas fa-user-circle me-2 text-primary"></i>Hồ sơ cá nhân</h4>
    <a asp-action="ChangePassword" class="btn btn-sm btn-outline-warning">
        <i class="fas fa-key me-1"></i>Đổi mật khẩu
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header bg-white d-flex align-items-center gap-3">
                <div style="width:48px;height:48px;border-radius:50%;background:#dbeafe;display:flex;align-items:center;justify-content:center">
                    <i class="fas fa-user text-primary fa-lg"></i>
                </div>
                <div>
                    <div class="fw-bold">@Model.FullName</div>
                    <span class="badge badge-role-@Model.Role">@Model.Role</span>
                </div>
            </div>
            <div class="card-body">
                <form asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Role" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Username</label>
                        <input class="form-control" value="@Model.Username" disabled />
                        <div class="form-text">Username không thể thay đổi</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold small"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold small"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label fw-semibold small"></label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                    </div>

                    @if (Model.Role == "Student")
                    {
                        <hr />
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Mã sinh viên</label>
                                <input class="form-control" value="@Model.StudentCode" disabled />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ClassName" class="form-label fw-semibold small"></label>
                                <input asp-for="ClassName" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="DateOfBirth" class="form-label fw-semibold small"></label>
                            <input asp-for="DateOfBirth" class="form-control" type="date" />
                        </div>
                    }

                    @if (Model.Role == "Teacher")
                    {
                        <hr />
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Mã giáo viên</label>
                                <input class="form-control" value="@Model.TeacherCode" disabled />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Degree" class="form-label fw-semibold small"></label>
                                <input asp-for="Degree" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Department" class="form-label fw-semibold small"></label>
                            <input asp-for="Department" class="form-control" />
                        </div>
                    }

                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Lưu thay đổi
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@model ExamSystem.ViewModels.RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Kích hoạt tài khoản";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kích hoạt tài khoản - ExamSystem</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 60%, #38bdf8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: "Segoe UI", sans-serif;
            padding: 24px 0;
        }
        .register-card {
            width: 520px;
            border-radius: 18px;
            box-shadow: 0 22px 50px rgba(15, 23, 42, .25);
        }
    </style>
</head>
<body>
    <div class="card register-card border-0">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="mb-3 text-primary" style="font-size:2.2rem"><i class="fas fa-user-check"></i></div>
                <h3 class="fw-bold mb-1">Kích hoạt tài khoản</h3>
                <p class="text-muted mb-0">Tự đặt mật khẩu mà không cần Gmail</p>
            </div>

            <div class="alert alert-light border small">
                Sinh viên dùng <strong>mã tài khoản + họ tên + ngày sinh</strong>.<br />
                Giáo viên dùng <strong>mã tài khoản + họ tên + số điện thoại</strong>.
            </div>

            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-semibold"></label>
                    <input asp-for="Username" class="form-control" placeholder="VD: GV001 hoặc 20230001" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold"></label>
                    <input asp-for="FullName" class="form-control" placeholder="Nhập đúng họ tên đã được cấp" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label fw-semibold"></label>
                        <input asp-for="Phone" class="form-control" placeholder="Dành cho giáo viên" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DateOfBirth" class="form-label fw-semibold"></label>
                        <input asp-for="DateOfBirth" class="form-control" type="date" />
                        <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                    <input asp-for="NewPassword" class="form-control" type="password" placeholder="Nhập mật khẩu mới" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Nhập lại mật khẩu" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-key me-2"></i>Kích hoạt và đặt mật khẩu
                </button>
            </form>

            <div class="text-center mt-4 d-flex justify-content-center gap-3">
                <a asp-action="Login" class="text-decoration-none">Đăng nhập</a>
                <a asp-action="ForgotPassword" class="text-decoration-none">Quên mật khẩu</a>
            </div>
        </div>
    </div>
</body>
</html>

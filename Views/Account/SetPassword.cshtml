@model ExamSystem.ViewModels.SetPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đặt mật khẩu";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đặt mật khẩu - ExamSystem</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 60%, #38bdf8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: "Segoe UI", sans-serif;
        }
        .password-card {
            width: 460px;
            border-radius: 18px;
            box-shadow: 0 22px 50px rgba(15, 23, 42, .25);
        }
    </style>
</head>
<body>
    <div class="card password-card border-0">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <h3 class="fw-bold mb-1">Đặt mật khẩu</h3>
                <p class="text-muted mb-0">Tạo mật khẩu riêng để hoàn tất quá trình xác thực</p>
            </div>

            <form asp-action="SetPassword" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="VerificationKey" type="hidden" />
                <input asp-for="Purpose" type="hidden" />
                <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                    <input asp-for="NewPassword" class="form-control" type="password" placeholder="Nhập mật khẩu mới" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Nhập lại mật khẩu mới" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Hoàn tất</button>
            </form>
        </div>
    </div>
</body>
</html>

@model ExamSystem.ViewModels.VerifyOtpViewModel
@{
    Layout = null;
    ViewData["Title"] = "Xác thực mã";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Xác thực mã - ExamSystem</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <style>
        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 60%, #38bdf8 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: "Segoe UI", sans-serif;
        }
        .otp-card {
            width: 420px;
            border-radius: 18px;
            box-shadow: 0 22px 50px rgba(15, 23, 42, .25);
        }
    </style>
</head>
<body>
    <div class="card otp-card border-0">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <h3 class="fw-bold mb-1">Nhập mã xác thực</h3>
                <p class="text-muted mb-0">Mã gồm 6 số đã được gửi tới <strong>@Model.MaskedEmail</strong></p>
            </div>

            <form asp-action="VerifyOtp" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="VerificationKey" type="hidden" />
                <input asp-for="Purpose" type="hidden" />
                <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                <div class="mb-4">
                    <label asp-for="Code" class="form-label fw-semibold"></label>
                    <input asp-for="Code" class="form-control form-control-lg text-center" maxlength="6" placeholder="000000" />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Xác nhận mã</button>
            </form>
        </div>
    </div>
</body>
</html>

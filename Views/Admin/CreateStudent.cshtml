@model ExamSystem.ViewModels.CreateStudentViewModel
@{
    ViewData["Title"] = "Thêm tài khoản Sinh viên";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Users" class="btn btn-sm btn-outline-secondary me-3">
        <i class="fas fa-arrow-left me-1"></i>Quay lại
    </a>
    <div>
        <h4 class="fw-bold mb-1"><i class="fas fa-user-graduate me-2 text-primary"></i>Thêm tài khoản Sinh viên</h4>
        <p class="text-muted mb-0">Admin chỉ tạo hồ sơ. Sinh viên sẽ tự đặt mật khẩu bằng mã tài khoản và ngày sinh.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header bg-white fw-semibold">
                <i class="fas fa-user-graduate text-primary me-2"></i>Thêm 1 sinh viên
            </div>
            <div class="card-body">
                <form asp-action="CreateStudent" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="StudentCode" class="form-label fw-semibold small"></label>
                            <input asp-for="StudentCode" class="form-control" placeholder="VD: 20231234" />
                            <span asp-validation-for="StudentCode" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold small"></label>
                            <input asp-for="FullName" class="form-control" placeholder="Họ và tên đầy đủ" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold small"></label>
                            <input asp-for="Email" class="form-control" placeholder="Có thể bỏ trống" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label fw-semibold small"></label>
                            <input asp-for="Phone" class="form-control" placeholder="Không bắt buộc" />
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="ClassName" class="form-label fw-semibold small"></label>
                            <input asp-for="ClassName" class="form-control" placeholder="VD: CNTT-K65" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DateOfBirth" class="form-label fw-semibold small"></label>
                            <input asp-for="DateOfBirth" class="form-control" type="date" />
                            <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Tạo tài khoản
                        </button>
                        <a asp-action="Users" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card h-100 border-primary-subtle">
            <div class="card-header bg-primary-subtle fw-semibold">
                <i class="fas fa-layer-group text-primary me-2"></i>Thêm nhiều sinh viên
            </div>
            <div class="card-body">
                <form asp-action="CreateStudent" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="BulkInput" class="form-label fw-semibold small"></label>
                        <textarea asp-for="BulkInput" class="form-control" rows="12" placeholder="20230001|Nguyen Van A|a@example.com|0909000001|CNTT-K65|2005-09-01&#10;20230002|Tran Thi B|b@example.com|0909000002|CNTT-K65|15/10/2005"></textarea>
                        <span asp-validation-for="BulkInput" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-light border small">
                        <div class="fw-semibold mb-2">Định dạng mỗi dòng</div>
                        <code>MaSV|HoTen|Email|SoDienThoai|Lop|NgaySinh</code>
                        <div class="mt-2 text-muted">Ngày sinh là bắt buộc để sinh viên tự kích hoạt. Hỗ trợ <code>yyyy-MM-dd</code> hoặc <code>dd/MM/yyyy</code>.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-upload me-1"></i>Tạo hàng loạt
                        </button>
                        <button type="button" class="btn btn-outline-secondary" onclick="fillStudentSample()">Điền mẫu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function fillStudentSample() {
            const area = document.getElementById('BulkInput');
            if (!area.value.trim()) {
                area.value = "20230001|Nguyen Van A|a@example.com|0909000001|CNTT-K65|2005-09-01\n20230002|Tran Thi B|b@example.com|0909000002|CNTT-K65|15/10/2005";
            }
        }
    </script>
}

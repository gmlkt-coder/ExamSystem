@model ExamSystem.ViewModels.EditUserViewModel
@{
    ViewData["Title"] = "Chỉnh sửa tài khoản";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Users" class="btn btn-sm btn-outline-secondary me-3">
        <i class="fas fa-arrow-left me-1"></i>Quay lại
    </a>
    <div>
        <h4 class="fw-bold mb-1"><i class="fas fa-user-edit me-2 text-primary"></i>Chỉnh sửa tài khoản</h4>
        <p class="text-muted mb-0">@Model.FullName — <code>@Model.Username</code></p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header bg-white fw-semibold">
                <span class="badge badge-role-@Model.Role me-2">@Model.Role</span>
                Thông tin tài khoản
            </div>
            <div class="card-body">
                <form asp-action="EditUser" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="Username" />
                    <input type="hidden" asp-for="Role" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Username</label>
                            <input class="form-control" value="@Model.Username" disabled />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label fw-semibold small"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold small"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label fw-semibold small"></label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                    </div>

                    @if (Model.Role == "Student")
                    {
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="ClassName" class="form-label fw-semibold small"></label>
                                <input asp-for="ClassName" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DateOfBirth" class="form-label fw-semibold small"></label>
                                <input asp-for="DateOfBirth" class="form-control" type="date" />
                            </div>
                        </div>
                    }

                    @if (Model.Role == "Teacher")
                    {
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Department" class="form-label fw-semibold small"></label>
                                <input asp-for="Department" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Degree" class="form-label fw-semibold small"></label>
                                <input asp-for="Degree" class="form-control" />
                            </div>
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Lưu thay đổi
                        </button>
                        <a asp-action="Users" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

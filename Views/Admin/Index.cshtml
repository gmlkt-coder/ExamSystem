@{
    ViewData["Title"] = "Dashboard - Admin";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold text-dark mb-1"><i class="fas fa-tachometer-alt me-2 text-primary"></i>Dashboard</h4>
        <p class="text-muted mb-0">Tổng quan hệ thống</p>
    </div>
</div>

<!-- STAT CARDS -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#1e40af,#3b82f6)">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="number">@ViewBag.TotalUsers</div>
                    <div class="label">Tổng người dùng</div>
                </div>
                <i class="fas fa-users fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#7c3aed,#a78bfa)">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="number">@ViewBag.TotalTeachers</div>
                    <div class="label">Giáo viên</div>
                </div>
                <i class="fas fa-chalkboard-teacher fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#065f46,#10b981)">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="number">@ViewBag.TotalStudents</div>
                    <div class="label">Sinh viên</div>
                </div>
                <i class="fas fa-user-graduate fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#b45309,#f59e0b)">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="number">@ViewBag.TotalExams</div>
                    <div class="label">Đề thi</div>
                </div>
                <i class="fas fa-file-alt fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<!-- QUICK ACTIONS -->
<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-white fw-semibold">
                <i class="fas fa-bolt text-primary me-2"></i>Thao tác nhanh
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-action="CreateTeacher" class="btn btn-outline-primary">
                        <i class="fas fa-user-plus me-2"></i>Thêm tài khoản Giáo viên
                    </a>
                    <a asp-action="CreateStudent" class="btn btn-outline-success">
                        <i class="fas fa-user-graduate me-2"></i>Thêm tài khoản Sinh viên
                    </a>
                    <a asp-action="Users" class="btn btn-outline-secondary">
                        <i class="fas fa-list me-2"></i>Xem danh sách tài khoản
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-white fw-semibold">
                <i class="fas fa-info-circle text-primary me-2"></i>Thông tin hệ thống
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless">
                    <tr><td class="text-muted">Phiên bản</td><td><strong>1.0.0</strong></td></tr>
                    <tr><td class="text-muted">Thời gian server</td><td><strong>@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</strong></td></tr>
                    <tr><td class="text-muted">Trạng thái</td><td><span class="badge bg-success">Hoạt động</span></td></tr>
                    <tr><td class="text-muted">Mã hóa mật khẩu</td><td><span class="badge bg-primary">BCrypt</span></td></tr>
                </table>
            </div>
        </div>
    </div>
</div>

@model IEnumerable<ExamSystem.Models.User>
@{
    ViewData["Title"] = "Quản lý tài khoản";
}

@section Styles {
    <style>
        .bulk-check {
            width: 1.3rem;
            height: 1.3rem;
            border: 2px solid #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.08);
        }
        .bulk-check:checked {
            background-color: #2563eb;
            border-color: #2563eb;
        }
        .bulk-column {
            width: 104px;
            background: #eff6ff;
        }
        .bulk-column .hint {
            color: #1d4ed8;
            font-weight: 600;
            font-size: .78rem;
        }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="fas fa-users me-2 text-primary"></i>Quản lý tài khoản</h4>
        <p class="text-muted mb-0">@Model.Count() tài khoản</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="CreateTeacher" class="btn btn-outline-primary btn-sm">
            <i class="fas fa-user-plus me-1"></i>Thêm GV
        </a>
        <a asp-action="CreateStudent" class="btn btn-primary btn-sm">
            <i class="fas fa-user-graduate me-1"></i>Thêm SV
        </a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-auto">
                <select name="role" class="form-select form-select-sm">
                    <option value="">Tất cả vai trò</option>
                    <option value="Teacher" selected="@(ViewBag.Role == "Teacher")">Giáo viên</option>
                    <option value="Student" selected="@(ViewBag.Role == "Student")">Sinh viên</option>
                </select>
            </div>
            <div class="col-auto">
                <input type="text" name="search" class="form-control form-control-sm" placeholder="Tìm kiếm..." value="@ViewBag.Search" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search me-1"></i>Tìm</button>
                <a asp-action="Users" class="btn btn-sm btn-outline-secondary ms-1">Xóa lọc</a>
            </div>
        </form>
    </div>
</div>

<form asp-action="DeleteUsers" method="post" id="bulkDeleteForm" onsubmit="return confirmBulkDelete()">
    @Html.AntiForgeryToken()
</form>

<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="fw-semibold">
            <i class="fas fa-list me-2 text-primary"></i>Danh sách tài khoản
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="small text-muted">Chọn ô trong cột "Chọn" để xóa nhiều tài khoản cùng lúc</span>
            <button type="submit" form="bulkDeleteForm" class="btn btn-sm btn-outline-danger">
                <i class="fas fa-trash me-1"></i>Xóa mục đã chọn
            </button>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="text-center bulk-column">
                            <div class="d-flex flex-column align-items-center gap-2 py-1">
                                <span class="hint">Chọn</span>
                                <input type="checkbox" id="checkAllUsers" class="form-check-input bulk-check" />
                            </div>
                        </th>
                        <th>Người dùng</th>
                        <th>Username</th>
                        <th>Vai trò</th>
                        <th>Thông tin thêm</th>
                        <th>Trạng thái</th>
                        <th>Kích hoạt</th>
                        <th>Ngày tạo</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr class="@(u.IsLocked ? "table-warning" : "")">
                            <td class="text-center bulk-column">
                                @if (u.Role != "Admin")
                                {
                                    <div class="d-flex flex-column align-items-center gap-2 py-1">
                                        <input type="checkbox" name="selectedUserIds" value="@u.UserId" form="bulkDeleteForm" class="form-check-input user-checkbox bulk-check" />
                                        <span class="hint">Chọn</span>
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-semibold">@u.FullName</div>
                                <small class="text-muted">@u.Email</small>
                            </td>
                            <td><code>@u.Username</code></td>
                            <td>
                                <span class="badge badge-role-@u.Role">@u.Role</span>
                            </td>
                            <td class="small text-muted">
                                @if (u.Teacher != null)
                                {
                                    <span>@u.Teacher.Department</span>
                                }
                                @if (u.Student != null)
                                {
                                    <span>Lớp: @u.Student.ClassName</span>
                                }
                            </td>
                            <td>
                                @if (u.IsLocked)
                                {
                                    <span class="badge bg-danger"><i class="fas fa-lock me-1"></i>Khóa</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="fas fa-check me-1"></i>Hoạt động</span>
                                }
                            </td>
                            <td>
                                @if (u.Role == "Admin")
                                {
                                    <span class="badge bg-secondary">Hệ thống</span>
                                }
                                else if (u.IsActivated)
                                {
                                    <span class="badge bg-success">Đã kích hoạt</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Chưa kích hoạt</span>
                                }
                            </td>
                            <td class="small text-muted">@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center flex-wrap">
                                    @if (u.Role != "Admin")
                                    {
                                        <a asp-action="EditUser" asp-route-id="@u.UserId"
                                           class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="ToggleLock" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.UserId" />
                                            <button type="submit" class="btn btn-sm @(u.IsLocked ? "btn-outline-success" : "btn-outline-warning")"
                                                    title="@(u.IsLocked ? "Mở khóa" : "Khóa")">
                                                <i class="fas @(u.IsLocked ? "fa-lock-open" : "fa-lock")"></i>
                                            </button>
                                        </form>
                                        <form asp-action="DeleteUser" method="post" class="d-inline"
                                              onsubmit="return confirm('Xóa tài khoản @u.FullName?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@u.UserId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('checkAllUsers')?.addEventListener('change', function () {
            document.querySelectorAll('.user-checkbox').forEach(cb => cb.checked = this.checked);
        });

        function confirmBulkDelete() {
            const checked = document.querySelectorAll('.user-checkbox:checked').length;
            if (checked === 0) {
                alert('Vui lòng chọn ít nhất 1 tài khoản để xóa.');
                return false;
            }

            return confirm('Xóa ' + checked + ' tài khoản đã chọn?');
        }
    </script>
}

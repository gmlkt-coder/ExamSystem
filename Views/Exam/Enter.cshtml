@model ExamSystem.ViewModels.ExamPasswordViewModel
@{
    ViewData["Title"] = "Vào thi - " + Model.ExamTitle;
}

<div class="d-flex align-items-center mb-4">
    <a asp-controller="Student" asp-action="Exams" class="btn btn-sm btn-outline-secondary me-3">
        <i class="fas fa-arrow-left me-1"></i>Quay lại
    </a>
    <h4 class="fw-bold mb-0"><i class="fas fa-door-open me-2 text-primary"></i>Vào thi</h4>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-white fw-semibold">
                <i class="fas fa-file-alt text-primary me-2"></i>@Model.ExamTitle
            </div>
            <div class="card-body">
                <!-- EXAM INFO -->
                <div class="row g-3 mb-4 text-center">
                    <div class="col-4">
                        <div class="p-3 bg-light rounded">
                            <div class="fw-bold text-primary fs-5">@Model.Duration</div>
                            <small class="text-muted">Phút</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-3 bg-light rounded">
                            <div class="fw-bold text-primary fs-5">@Model.QuestionCount</div>
                            <small class="text-muted">Câu hỏi</small>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-3 bg-light rounded">
                            <div class="fw-bold text-primary fs-5">@(Model.Subject ?? "—")</div>
                            <small class="text-muted">Môn học</small>
                        </div>
                    </div>
                </div>

                <div class="alert alert-warning py-2 small mb-4">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Sau khi vào thi, đồng hồ sẽ bắt đầu đếm ngược. Bài thi sẽ tự động nộp khi hết giờ.
                </div>

                <form asp-action="Enter" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ExamId" />

                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-semibold small"></label>
                        <input asp-for="Password" class="form-control" type="password"
                               placeholder="Nhập mật khẩu bài thi" autofocus />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        <i class="fas fa-play me-2"></i>Bắt đầu làm bài
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@model ExamSystem.Models.PracticeExam
@{
    ViewData["Title"] = "Kết quả luyện tập";
    Layout = null;
    var score = (decimal)(ViewBag.Score ?? 0);
    var maxScore = (decimal)(ViewBag.MaxScore ?? 0);
    var pct = maxScore > 0 ? (double)score / (double)maxScore * 100 : 0;
    var selectedAnswers = (Dictionary<int, int>)(ViewBag.SelectedAnswers ?? new Dictionary<int, int>());
    var essayAnswers = (Dictionary<int, string>)(ViewBag.EssayAnswers ?? new Dictionary<int, string>());
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kết quả luyện tập</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body { background: #f1f5f9; font-family: 'Segoe UI', sans-serif; }
        .answer-opt { padding: .7rem 1rem; border-radius: 8px; margin-bottom: .4rem; border: 2px solid #e2e8f0; }
        .answer-opt.correct { border-color: #16a34a; background: #dcfce7; }
        .answer-opt.wrong { border-color: #dc2626; background: #fee2e2; }
    </style>
</head>
<body>
    <div style="background:#1e293b;color:white;padding:1rem 2rem" class="mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <span class="fw-bold">Kết quả: @Model.Title</span>
            <a href="/Student/Practice" class="btn btn-sm btn-outline-light">
                <i class="fas fa-arrow-left me-1"></i>Quay lại
            </a>
        </div>
    </div>

    <div class="container" style="max-width:800px">
        <!-- SCORE -->
        <div class="card text-center p-4 mb-4">
            <div class="mb-3">
                <div style="width:100px;height:100px;border-radius:50%;border:8px solid @(pct>=80?"#16a34a":pct>=50?"#2563eb":"#dc2626");display:flex;align-items:center;justify-content:center;margin:0 auto">
                    <div>
                        <div style="font-size:1.8rem;font-weight:800">@score.ToString("F0")</div>
                        <div class="small text-muted">/ @maxScore.ToString("F0")</div>
                    </div>
                </div>
            </div>
            <h5 class="fw-bold">@(pct >= 80 ? "🎉 Xuất sắc!" : pct >= 60 ? "👍 Khá tốt!" : pct >= 50 ? "😐 Trung bình" : "😔 Cần ôn thêm")</h5>
            <p class="text-muted">Đạt @pct.ToString("F0")% số điểm</p>

            <div class="d-flex justify-content-center gap-3 mt-2">
                <a href="/Exam/TakePractice/@Model.PracticeExamId" class="btn btn-primary">
                    <i class="fas fa-redo me-1"></i>Làm lại
                </a>
                <a href="/Student/Practice" class="btn btn-outline-secondary">
                    <i class="fas fa-list me-1"></i>Danh sách đề
                </a>
            </div>
        </div>

        <!-- REVIEW ANSWERS -->
        <h6 class="fw-bold mb-3">Xem lại đáp án</h6>
        @foreach (var (q, i) in Model.Questions.OrderBy(q => q.OrderIndex).Select((q, i) => (q, i)))
        {
            var selected = selectedAnswers.ContainsKey(q.PracticeQuestionId) ? selectedAnswers[q.PracticeQuestionId] : 0;
            var isCorrect = q.Answers.Any(a => a.PracticeAnswerId == selected && a.IsCorrect);

            <div class="card mb-3 @(q.QuestionType != "Essay" ? (isCorrect ? "border-success" : "border-danger") : "") border">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="fw-semibold text-muted small">Câu @(i+1)</span>
                        @if (q.QuestionType != "Essay")
                        {
                            if (isCorrect)
                            {
                                <span class="badge bg-success"><i class="fas fa-check me-1"></i>Đúng</span>
                            }
                            else
                            {
                                <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Sai</span>
                            }
                        }
                    </div>
                    <p class="mb-3">@q.QuestionText</p>

                    @if (q.QuestionType != "Essay")
                    {
                        @foreach (var a in q.Answers.OrderBy(a => a.OrderIndex))
                        {
                            var isSelectedAnswer = a.PracticeAnswerId == selected;
                            var cls = a.IsCorrect ? "correct" : (isSelectedAnswer && !a.IsCorrect ? "wrong" : "");
                            <div class="answer-opt @cls">
                                @if (a.IsCorrect) { <i class="fas fa-check text-success me-2"></i> }
                                else if (isSelectedAnswer) { <i class="fas fa-times text-danger me-2"></i> }
                                else { <span class="me-2">○</span> }
                                @a.AnswerText
                            </div>
                        }
                    }
                    else
                    {
                        var essayText = essayAnswers.ContainsKey(q.PracticeQuestionId)
                            ? essayAnswers[q.PracticeQuestionId]
                            : "";
                        <div class="bg-light border rounded p-3">
                            <div class="text-muted small mb-1">Bài làm của bạn:</div>
                            <div>@(string.IsNullOrWhiteSpace(essayText) ? "(Không có câu trả lời)" : essayText)</div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(q.Explanation))
                    {
                        <div class="alert alert-light border mt-2 mb-0 py-2 small">
                            <i class="fas fa-lightbulb text-warning me-2"></i>
                            <strong>Giải thích:</strong> @q.Explanation
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
</body>
</html>

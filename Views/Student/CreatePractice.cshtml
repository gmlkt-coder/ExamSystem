@model ExamSystem.ViewModels.CreatePracticeExamViewModel
@{
    ViewData["Title"] = "Tạo đề luyện tập";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Practice" class="btn btn-sm btn-outline-secondary me-3">
        <i class="fas fa-arrow-left me-1"></i>Quay lại
    </a>
    <h4 class="fw-bold mb-0"><i class="fas fa-plus-circle me-2 text-primary"></i>Tạo đề luyện tập</h4>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body p-4">
                <form asp-action="CreatePractice" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold small"></label>
                        <input asp-for="Title" class="form-control" placeholder="VD: Ôn tập chương 1" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold small"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Mô tả (không bắt buộc)"></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-arrow-right me-1"></i>Tạo và thêm câu hỏi
                        </button>
                        <a asp-action="Practice" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@model IEnumerable<ExamSystem.ViewModels.ExamListItemViewModel>
@{
    ViewData["Title"] = "Danh sách đề thi";
    var mySubmissions = (List<int>)ViewBag.MySubmissions;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="fas fa-list-alt me-2 text-primary"></i>Danh sách đề thi</h4>
        <p class="text-muted mb-0">@Model.Count() đề thi đang mở</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="fas fa-inbox fa-3x mb-3 opacity-25"></i>
            <p>Hiện chưa có đề thi nào được công bố.</p>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var exam in Model)
        {
            var done = mySubmissions.Contains(exam.ExamId);
            <div class="col-md-6 col-xl-4">
                <div class="card exam-card h-100 @(done ? "border-success" : "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            @if (done)
                            {
                                <span class="badge bg-success"><i class="fas fa-check me-1"></i>Đã làm</span>
                            }
                            else
                            {
                                <span class="badge bg-primary"><i class="fas fa-file-alt me-1"></i>Chưa làm</span>
                            }
                            <small class="text-muted">@exam.Duration phút</small>
                        </div>
                        <h6 class="fw-bold mb-1">@exam.Title</h6>
                        <p class="text-muted small mb-2">@(exam.Subject ?? "—")</p>
                        <div class="d-flex gap-3 text-muted small mb-2">
                            <span><i class="fas fa-question-circle me-1"></i>@exam.QuestionCount câu</span>
                            <span><i class="fas fa-user me-1"></i>@exam.TeacherName</span>
                        </div>
                        @if (exam.StartTime.HasValue)
                        {
                            <small class="text-muted">
                                <i class="fas fa-calendar me-1"></i>
                                @exam.StartTime.Value.ToString("dd/MM/yyyy HH:mm") —
                                @exam.EndTime?.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        }
                    </div>
                    <div class="card-footer bg-white border-0 pt-0">
                        @if (done)
                        {
                            <button class="btn btn-outline-success btn-sm w-100" disabled>
                                <i class="fas fa-check me-1"></i>Đã hoàn thành
                            </button>
                        }
                        else
                        {
                            <a asp-controller="Exam" asp-action="Enter" asp-route-id="@exam.ExamId"
                               class="btn btn-primary btn-sm w-100">
                                <i class="fas fa-play me-1"></i>Vào thi
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

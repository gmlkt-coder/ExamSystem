@model IEnumerable<ExamSystem.Models.ExamSubmission>
@{
    ViewData["Title"] = "Lịch sử làm bài";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="fas fa-history me-2 text-primary"></i>Lịch sử làm bài</h4>
        <p class="text-muted mb-0">@Model.Count() bài thi</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="fas fa-history fa-3x mb-3 opacity-25"></i>
            <p>Bạn chưa làm bài thi nào.</p>
            <a asp-action="Exams" class="btn btn-primary btn-sm">
                <i class="fas fa-list me-1"></i>Xem danh sách đề thi
            </a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Đề thi</th>
                            <th>Thời gian nộp</th>
                            <th class="text-center">Điểm</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sub in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@sub.Exam.Title</div>
                                    <small class="text-muted">@sub.Exam.Subject</small>
                                </td>
                                <td class="small text-muted">
                                    @(sub.SubmittedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                                    @if (sub.IsAutoSubmit)
                                    {
                                        <span class="badge bg-warning text-dark ms-1">Tự động</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (sub.TotalScore.HasValue)
                                    {
                                        <span class="fw-bold @(sub.TotalScore >= 5 ? "text-success" : "text-danger") fs-6">
                                            @sub.TotalScore.Value.ToString("F1")
                                        </span>
                                        <small class="text-muted">/@sub.Exam.MaxScore</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (sub.Status == "Graded")
                                    {
                                        <span class="badge bg-success">Đã chấm</span>
                                    }
                                    else if (sub.Status == "Submitted")
                                    {
                                        <span class="badge bg-warning text-dark">Chờ chấm</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đang làm</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (sub.Status == "InProgress")
                                    {
                                        <a asp-controller="Exam" asp-action="Take"
                                           asp-route-submissionId="@sub.SubmissionId"
                                           class="btn btn-sm btn-warning">
                                            <i class="fas fa-play me-1"></i>Tiếp tục
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Exam" asp-action="Result"
                                           asp-route-id="@sub.SubmissionId"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye me-1"></i>Xem kết quả
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

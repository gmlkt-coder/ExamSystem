@model IEnumerable<ExamSystem.Models.PracticeExam>
@{
    ViewData["Title"] = "Đề luyện tập";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="fas fa-dumbbell me-2 text-primary"></i>Đề luyện tập</h4>
        <p class="text-muted mb-0">Tự tạo đề và luyện tập không giới hạn</p>
    </div>
    <a asp-action="CreatePractice" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Tạo đề luyện tập
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="fas fa-dumbbell fa-3x mb-3 opacity-25"></i>
            <p>Bạn chưa có đề luyện tập nào.</p>
            <a asp-action="CreatePractice" class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i>Tạo đề luyện tập đầu tiên
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var p in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card exam-card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-info text-dark">Luyện tập</span>
                            <small class="text-muted">@p.CreatedAt.ToString("dd/MM/yyyy")</small>
                        </div>
                        <h6 class="fw-bold mb-1">@p.Title</h6>
                        <p class="text-muted small mb-3">@(p.Description ?? "Không có mô tả")</p>
                        <div class="d-flex gap-3 text-muted small">
                            <span><i class="fas fa-question-circle me-1"></i>@p.Questions.Count câu hỏi</span>
                            <span><i class="fas fa-redo me-1"></i>@p.Submissions.Count lần làm</span>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 pt-0 d-flex gap-2">
                        <a asp-action="EditPractice" asp-route-id="@p.PracticeExamId"
                           class="btn btn-outline-secondary btn-sm flex-fill">
                            <i class="fas fa-edit me-1"></i>Chỉnh sửa
                        </a>
                        @if (p.Questions.Any())
                        {
                            <a asp-controller="Exam" asp-action="TakePractice" asp-route-id="@p.PracticeExamId"
                               class="btn btn-primary btn-sm flex-fill">
                                <i class="fas fa-play me-1"></i>Làm bài
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

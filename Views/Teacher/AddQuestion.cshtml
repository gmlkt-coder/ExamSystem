@model ExamSystem.ViewModels.AddQuestionViewModel
@{
    ViewData["Title"] = "Thêm câu hỏi";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="EditExam" asp-route-id="@Model.ExamId" class="btn btn-sm btn-outline-secondary me-3">
        <i class="fas fa-arrow-left me-1"></i>Quay lại
    </a>
    <div>
        <h4 class="fw-bold mb-1"><i class="fas fa-plus-circle me-2 text-primary"></i>Thêm câu hỏi</h4>
        <p class="text-muted mb-0">@Model.ExamTitle</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="AddQuestion" method="post" id="questionForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ExamId" />
                    <input type="hidden" asp-for="ExamTitle" />

                    <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <div class="mb-3">
                        <label asp-for="QuestionText" class="form-label fw-semibold small"></label>
                        <textarea asp-for="QuestionText" class="form-control" rows="3" placeholder="Nhập nội dung câu hỏi..."></textarea>
                        <span asp-validation-for="QuestionText" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="QuestionType" class="form-label fw-semibold small"></label>
                            <select asp-for="QuestionType" class="form-select" id="questionType" onchange="toggleAnswers()">
                                <option value="MultipleChoice">Trắc nghiệm</option>
                                <option value="TrueFalse">Đúng / Sai</option>
                                <option value="Essay">Tự luận</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Points" class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <input asp-for="Points" class="form-control" type="number" step="0.25" min="0.25" />
                                <span class="input-group-text">điểm</span>
                            </div>
                        </div>
                    </div>

                    <!-- MULTIPLE CHOICE ANSWERS -->
                    <div id="answersSection">
                        <label class="form-label fw-semibold small">Các đáp án <span class="text-muted">(tick vào ô đáp án đúng)</span></label>
                        @for (int i = 0; i < Model.Answers.Count; i++)
                        {
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="fw-bold text-muted" style="width:24px">@("ABCD"[i]).</span>
                                <input type="text" name="Answers[@i].AnswerText"
                                       class="form-control form-control-sm"
                                       placeholder="Nhập đáp án @("ABCD"[i])"
                                       value="@Model.Answers[i].AnswerText" />
                                <div class="form-check mb-0">
                                    <input type="checkbox" name="Answers[@i].IsCorrect"
                                           class="form-check-input" value="true"
                                           @(Model.Answers[i].IsCorrect ? "checked" : "")
                                           id="correct_@i" />
                                    <label class="form-check-label small text-success fw-semibold" for="correct_@i">Đúng</label>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- TRUE/FALSE ANSWERS -->
                    <div id="trueFalseSection" style="display:none">
                        <label class="form-label fw-semibold small">Đáp án đúng</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input type="radio" class="form-check-input" name="trueFalseCorrect" id="trueOpt" value="true" checked />
                                <label class="form-check-label" for="trueOpt">✅ Đúng</label>
                            </div>
                            <div class="form-check">
                                <input type="radio" class="form-check-input" name="trueFalseCorrect" id="falseOpt" value="false" />
                                <label class="form-check-label" for="falseOpt">❌ Sai</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3 mt-3">
                        <label asp-for="Explanation" class="form-label fw-semibold small"></label>
                        <textarea asp-for="Explanation" class="form-control form-control-sm" rows="2"
                                  placeholder="Giải thích đáp án (không bắt buộc)"></textarea>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Thêm câu hỏi
                        </button>
                        <a asp-action="EditExam" asp-route-id="@Model.ExamId" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleAnswers() {
            const type = document.getElementById('questionType').value;
            document.getElementById('answersSection').style.display = type === 'MultipleChoice' ? 'block' : 'none';
            document.getElementById('trueFalseSection').style.display = type === 'TrueFalse' ? 'block' : 'none';
        }
        toggleAnswers();
    </script>
}

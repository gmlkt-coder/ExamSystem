@model ExamSystem.ViewModels.CreateExamViewModel
@{
    ViewData["Title"] = "Tạo đề thi mới";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Exams" class="btn btn-sm btn-outline-secondary me-3">
        <i class="fas fa-arrow-left me-1"></i>Quay lại
    </a>
    <div>
        <h4 class="fw-bold mb-1"><i class="fas fa-plus-circle me-2 text-primary"></i>Tạo đề thi mới</h4>
        <p class="text-muted mb-0">Điền thông tin đề thi, sau đó thêm câu hỏi</p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-white fw-semibold">
                <i class="fas fa-file-alt text-primary me-2"></i>Thông tin đề thi
            </div>
            <div class="card-body">
                <form asp-action="CreateExam" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-8">
                            <label asp-for="Title" class="form-label fw-semibold small"></label>
                            <input asp-for="Title" class="form-control" placeholder="VD: Kiểm tra giữa kỳ môn CNTT" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Subject" class="form-label fw-semibold small"></label>
                            <input asp-for="Subject" class="form-control" placeholder="VD: Lập trình Web" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold small"></label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả đề thi (không bắt buộc)"></textarea>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="Duration" class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <input asp-for="Duration" class="form-control" type="number" min="1" max="300" />
                                <span class="input-group-text">phút</span>
                            </div>
                            <span asp-validation-for="Duration" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MaxScore" class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <input asp-for="MaxScore" class="form-control" type="number" step="0.5" min="1" />
                                <span class="input-group-text">điểm</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Password" class="form-label fw-semibold small"></label>
                            <input asp-for="Password" class="form-control" placeholder="Để trống nếu không cần" />
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartTime" class="form-label fw-semibold small"></label>
                            <input asp-for="StartTime" class="form-control" type="datetime-local" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndTime" class="form-label fw-semibold small"></label>
                            <input asp-for="EndTime" class="form-control" type="datetime-local" />
                        </div>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="AllowReview" class="form-check-input" type="checkbox" />
                        <label asp-for="AllowReview" class="form-check-label">
                            Cho phép sinh viên xem lại đáp án sau khi chấm
                        </label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-arrow-right me-1"></i>Tạo và thêm câu hỏi
                        </button>
                        <a asp-action="Exams" class="btn btn-outline-secondary">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

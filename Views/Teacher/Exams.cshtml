@model IEnumerable<ExamSystem.ViewModels.ExamListItemViewModel>
@{
    ViewData["Title"] = "Danh sách đề thi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="fas fa-file-alt me-2 text-primary"></i>Danh sách đề thi</h4>
        <p class="text-muted mb-0">@Model.Count() đề thi</p>
    </div>
    <a asp-action="CreateExam" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Tạo đề thi mới
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5 text-muted">
            <i class="fas fa-file-circle-plus fa-3x mb-3 opacity-25"></i>
            <p class="mb-3">Chưa có đề thi nào. Hãy tạo đề thi đầu tiên!</p>
            <a asp-action="CreateExam" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i>Tạo đề thi mới
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var exam in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card exam-card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge @(exam.IsPublished ? "bg-success" : "bg-secondary")">
                                <i class="fas @(exam.IsPublished ? "fa-broadcast-tower" : "fa-eye-slash") me-1"></i>
                                @(exam.IsPublished ? "Đã công bố" : "Nháp")
                            </span>
                            <small class="text-muted">@exam.CreatedAt.ToString("dd/MM/yyyy")</small>
                        </div>
                        <h6 class="fw-bold mb-1">@exam.Title</h6>
                        <p class="text-muted small mb-3">@(exam.Subject ?? "Chưa có môn học")</p>
                        <div class="d-flex gap-3 text-muted small mb-3">
                            <span><i class="fas fa-clock me-1"></i>@exam.Duration phút</span>
                            <span><i class="fas fa-question-circle me-1"></i>@exam.QuestionCount câu</span>
                        </div>
                        @if (exam.StartTime.HasValue)
                        {
                            <small class="text-muted d-block mb-2">
                                <i class="fas fa-calendar me-1"></i>@exam.StartTime.Value.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        }
                    </div>
                    <div class="card-footer bg-white border-0 pt-0">
                        <a asp-action="EditExam" asp-route-id="@exam.ExamId" class="btn btn-primary btn-sm w-100">
                            <i class="fas fa-edit me-1"></i>Quản lý đề thi
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@model ExamSystem.ViewModels.GradeSubmissionViewModel
@{
    ViewData["Title"] = "Chấm bài";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Submissions" asp-route-examId="@Model.ExamId" class="btn btn-sm btn-outline-secondary me-3">
        <i class="fas fa-arrow-left me-1"></i>Quay lại
    </a>
    <div>
        <h4 class="fw-bold mb-1"><i class="fas fa-pen me-2 text-primary"></i>Chấm bài</h4>
        <p class="text-muted mb-0">
            @Model.ExamTitle —
            <strong>@Model.StudentName</strong> (@Model.StudentCode)
        </p>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <form asp-action="GradeSubmission" asp-route-id="@Model.SubmissionId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="SubmissionId" value="@Model.SubmissionId" />
            <input type="hidden" name="ExamId" value="@Model.ExamId" />

            @if (!Model.EssayQuestions.Any())
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    Đề thi này không có câu tự luận. Bài đã được chấm tự động.
                </div>
            }
            else
            {
                <div class="card mb-3">
                    <div class="card-header bg-white fw-semibold">
                        <i class="fas fa-pen-alt text-warning me-2"></i>Câu tự luận cần chấm
                    </div>
                    <div class="card-body">
                        @foreach (var q in Model.EssayQuestions)
                        {
                            <div class="mb-4 p-3 border rounded">
                                <div class="fw-semibold mb-2">@q.QuestionText</div>
                                <div class="bg-light p-3 rounded mb-3">
                                    <small class="text-muted d-block mb-1">Bài làm của sinh viên:</small>
                                    <p class="mb-0">@(string.IsNullOrEmpty(q.EssayAnswer) ? "(Không có câu trả lời)" : q.EssayAnswer)</p>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <label class="fw-semibold small">Điểm (tối đa @q.Points):</label>
                                    <input type="number"
                                           name="essayScores[@q.StudentAnswerId]"
                                           class="form-control form-control-sm"
                                           style="width:100px"
                                           value="@(q.ScoreEarned ?? 0)"
                                           min="0" max="@q.Points" step="0.25" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="card mb-3">
                <div class="card-header bg-white fw-semibold">
                    <i class="fas fa-comment-dots text-primary me-2"></i>Nhận xét
                </div>
                <div class="card-body">
                    <textarea name="TeacherComment" class="form-control" rows="4"
                              placeholder="Nhận xét cho sinh viên (không bắt buộc)">@Model.TeacherComment</textarea>
                </div>
            </div>

            <button type="submit" class="btn btn-success btn-lg">
                <i class="fas fa-check me-2"></i>Hoàn thành chấm bài
            </button>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="card sticky-top" style="top:80px">
            <div class="card-header bg-white fw-semibold">
                <i class="fas fa-chart-pie text-primary me-2"></i>Tóm tắt
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless">
                    <tr>
                        <td class="text-muted">Sinh viên</td>
                        <td><strong>@Model.StudentName</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted">Điểm tự động</td>
                        <td><strong class="text-primary">@Model.AutoScore?.ToString("F2")</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted">Câu tự luận</td>
                        <td><strong>@Model.EssayQuestions.Count câu</strong></td>
                    </tr>
                    <tr>
                        <td class="text-muted">Thang điểm</td>
                        <td><strong>@Model.MaxScore</strong></td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>

@* Teacher/Index.cshtml *@
@{
    ViewData["Title"] = "Dashboard - Giáo viên";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="fas fa-tachometer-alt me-2 text-primary"></i>Dashboard Giáo viên</h4>
        <p class="text-muted mb-0">Xin chào, @User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</p>
    </div>
    <a asp-action="CreateExam" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Tạo đề thi mới
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#1e40af,#3b82f6)">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="number">@ViewBag.TotalExams</div><div class="label">Tổng đề thi</div></div>
                <i class="fas fa-file-alt fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#065f46,#10b981)">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="number">@ViewBag.PublishedExams</div><div class="label">Đã công bố</div></div>
                <i class="fas fa-broadcast-tower fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#7c3aed,#a78bfa)">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="number">@ViewBag.TotalSubmissions</div><div class="label">Bài nộp</div></div>
                <i class="fas fa-inbox fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="background:linear-gradient(135deg,#b45309,#f59e0b)">
            <div class="d-flex justify-content-between align-items-start">
                <div><div class="number">@ViewBag.PendingGrading</div><div class="label">Chờ chấm bài</div></div>
                <i class="fas fa-pen fa-2x opacity-50"></i>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white fw-semibold">
        <i class="fas fa-bolt text-primary me-2"></i>Thao tác nhanh
    </div>
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-3">
                <a asp-action="CreateExam" class="btn btn-outline-primary w-100">
                    <i class="fas fa-plus-circle me-2"></i>Tạo đề thi mới
                </a>
            </div>
            <div class="col-md-3">
                <a asp-action="Exams" class="btn btn-outline-secondary w-100">
                    <i class="fas fa-list me-2"></i>Danh sách đề thi
                </a>
            </div>
        </div>
    </div>
</div>
